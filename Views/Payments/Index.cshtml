@model IReadOnlyList<PaymentTransaction>
@{
    ViewData["Title"] = "Payments";
}

<div class="page-head page-head--ruled d-flex justify-content-between align-items-end gap-2 mt-3">
    <div>
        <p class="eyebrow mb-1">PAYMENT PROCESSING</p>
        <h1 class="h3 mb-0">Payment Transactions</h1>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Record Payment</a>
    </div>
</div>

<div class="modal fade"
     id="confirmPaymongoModal"
     tabindex="-1"
     aria-labelledby="confirmPaymongoModalLabel"
     aria-describedby="confirmPaymongoModalDescription confirmPaymongoModalHint"
     aria-modal="true"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmPaymongoModalLabel">Confirm PayMongo Payment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2 modal-primary-copy" id="confirmPaymongoModalDescription" data-confirm-label>Are you sure you want to confirm this PayMongo payment?</p>
                <p class="small modal-support-copy mb-0" id="confirmPaymongoModalHint">This will mark the payment as completed and update the invoice balance.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmPaymongoSubmit">Confirm Payment</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const modalElement = document.getElementById("confirmPaymongoModal");
            const confirmButton = document.getElementById("confirmPaymongoSubmit");
            if (!modalElement || !confirmButton || !window.bootstrap) {
                return;
            }

            if (modalElement.parentElement !== document.body) {
                document.body.appendChild(modalElement);
            }

            const label = modalElement.querySelector("[data-confirm-label]");
            const modal = new bootstrap.Modal(modalElement);
            let pendingForm = null;

            document.querySelectorAll(".js-confirm-paymongo").forEach((button) => {
                button.addEventListener("click", () => {
                    pendingForm = button.closest("form");
                    const text = button.getAttribute("data-payment-label");
                    if (label && text) {
                        label.textContent = text;
                    }
                    modal.show();
                });
            });

            confirmButton.addEventListener("click", () => {
                if (pendingForm) {
                    pendingForm.submit();
                }
            });
        })();
    </script>
}

<div class="solid-card p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle moneta-table moneta-table--id">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Invoice</th>
                    <th>Client</th>
                    <th>Amount</th>
                    <th>Method</th>
                    <th>Status</th>
                    <th>Reference</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr class="empty-state-row"><td colspan="8"><div class="empty-state"><div class="empty-state-icon">💳</div><h3>No transactions yet</h3><p>Recorded payments will appear here.</p></div></td></tr>
            }
            else
            {
                @foreach (var payment in Model)
                {
                    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
                    <tr>
                        <td>@payment.PaidAtUtc.ToLocalTime().ToString("MMM dd, yyyy")</td>
                        <td><a asp-controller="Invoices" asp-action="Details" asp-route-id="@payment.InvoiceId">@payment.Invoice?.InvoiceNumber</a></td>
                        <td>@payment.Invoice?.ClientAccount?.CompanyName</td>
                        <td>@payment.Amount.ToString("N2")</td>
                        <td>@payment.Method</td>
                        <td><span class="badge-status @payment.Status.ToLowerInvariant()">@payment.Status</span></td>
                        <td>@payment.ReferenceNumber</td>
                        <td>
                            @if (payment.Method == DomainValues.PaymentMethod.PayMongo
                               && payment.Status == DomainValues.PaymentStatus.Pending)
                            {
                                <form asp-action="ConfirmPayMongo" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@payment.Id" />
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary js-confirm-paymongo"
                                            data-payment-label="@($"Confirm PayMongo payment of {payment.Amount:N2} for invoice {payment.Invoice?.InvoiceNumber}")">
                                        Confirm
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
