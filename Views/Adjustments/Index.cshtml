@model IReadOnlyList<CreditDebitAdjustment>
@{
    ViewData["Title"] = "Credit & Debit Management";
}

<div class="page-head page-head--ruled d-flex justify-content-between align-items-end gap-2 mt-3">
    <div>
        <p class="eyebrow mb-1">CREDIT & DEBIT MANAGEMENT</p>
        <h1 class="h3 mb-0">Financial Adjustments</h1>
    </div>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">Apply Adjustment</a>
    </div>
</div>

<div class="solid-card p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle moneta-table moneta-table--id">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Invoice</th>
                    <th>Client</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>Reason</th>
                    <th>By</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr class="empty-state-row"><td colspan="7"><div class="empty-state"><div class="empty-state-icon">⚖️</div><h3>No adjustments yet</h3><p>Credit and debit adjustments to invoices will appear here.</p></div></td></tr>
            }
            else
            {
                @foreach (var row in Model)
                {
                    <tr>
                        <td>@row.AppliedAtUtc.ToLocalTime().ToString("MMM dd, yyyy")</td>
                        <td><a asp-controller="Invoices" asp-action="Details" asp-route-id="@row.InvoiceId">@row.Invoice?.InvoiceNumber</a></td>
                        <td>@row.Invoice?.ClientAccount?.CompanyName</td>
                        <td>@row.Type</td>
                        <td>@row.Amount.ToString("N2")</td>
                        <td>@(string.IsNullOrWhiteSpace(row.Reason) ? "No reason provided" : row.Reason)</td>
                        <td>@row.CreatedByUser?.FullName</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
