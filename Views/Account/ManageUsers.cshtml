@model MonetaCore.ViewModels.ManageUsersViewModel
@{
    ViewData["Title"] = "Manage Users";
}

<div class="page-head mb-4">
    <div>
        <p class="eyebrow mb-2">User Management</p>
        <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
            <h1 class="hero-title mb-0">Manage users</h1>
            <span class="badge-status pending review-count-badge">@Model.Users.Count users</span>
        </div>
        <p class="text-muted mb-0">Main Admin can manage standard user accounts. Super Admin can manage every account.</p>
    </div>
</div>

@if (Model.Users.Count == 0)
{
    <div class="glass-card p-4 p-md-5 text-center">
        <h2 class="h4 mb-2">No users available</h2>
        <p class="text-muted mb-0">There are no user accounts visible for your current role.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 moneta-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@user.FullName</div>
                            <div class="small text-muted">User ID: @user.Id</div>
                        </td>
                        <td>@user.Email</td>
                        <td>@user.Role</td>
                        <td>
                            <span class="badge-status @(user.IsActive ? "paid" : "cancelled")">
                                @(user.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>@user.CreatedAtUtc.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt")</td>
                        <td>
                            <div class="d-flex justify-content-end gap-2 flex-wrap">
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-light">Edit</a>
                                <form asp-action="ToggleUserStatus" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                        @(user.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}