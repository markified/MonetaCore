@model MonetaCore.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Edit User";
}

<div class="page-head mb-4">
    <div>
        <p class="eyebrow mb-2">User Management</p>
        <h1 class="hero-title mb-1">Edit user</h1>
        <p class="text-muted mb-0">Update account details, role assignment, and active status.</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-xl-6 col-lg-7 col-md-9">
        <div class="glass-card p-4 p-md-5">
            <form asp-action="EditUser" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control form-control-lg" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control form-control-lg" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="form-label"></label>
                    <select asp-for="Role" class="form-select form-select-lg">
                        @foreach (var role in Model.AvailableRoles)
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                    <span asp-validation-for="IsActive" class="text-danger small d-block"></span>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary">Save changes</button>
                    <a asp-action="ManageUsers" class="btn btn-outline-secondary">Back to Manage Users</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}