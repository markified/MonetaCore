@using MonetaCore.Models
@model MonetaCore.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Edit User";
    bool isSuperAdmin = User.IsInRole(ApplicationRoles.SuperAdmin);

    string[] assignableRoles = isSuperAdmin
        ? ApplicationRoles.AllRoles
        : ApplicationRoles.AllRoles
            .Where(r => r != ApplicationRoles.SuperAdmin && r != ApplicationRoles.MainAdmin)
            .ToArray();
}

<div class="page-head page-head--ruled mb-4">
    <div>
        <p class="eyebrow mb-2">User Management</p>
        <h1 class="hero-title mb-1">Edit User</h1>
        <p class="text-muted mb-0">@Model.FullName — #@Model.Id</p>
    </div>
</div>

<div class="glass-card p-4 p-md-5" style="max-width:540px;">
    <form asp-action="EditUser" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="FullName" class="form-label">Full Name</label>
            <input asp-for="FullName" class="form-control" />
            <span asp-validation-for="FullName" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" type="email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Role" class="form-label">Role</label>
            <select asp-for="Role" class="form-select">
                @foreach (var r in assignableRoles)
                {
                    <option value="@r" selected="@(Model.Role == r)">@r</option>
                }
            </select>
            <span asp-validation-for="Role" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                <label asp-for="IsActive" class="form-check-label">Active</label>
            </div>
        </div>

        <hr class="my-4" />

        <p class="text-muted small mb-3">
            Leave the password fields blank to keep the existing password.
        </p>

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label">New Password</label>
            <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="NewPassword" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmNewPassword" class="form-label">Confirm New Password</label>
            <input asp-for="ConfirmNewPassword" type="password" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="ManageUsers" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
